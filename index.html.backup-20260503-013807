<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="SKS SHOPPING - L'élégance livrée à votre porte. Boutique multi-niches premium." />
  <title>SKS SHOPPING - L'élégance livrée à votre porte</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="assets/css/style.css" />
</head>
<body>
  <div class="top-bar">✦ Livraison gratuite dès 50€ • Retours offerts 30 jours • Service client 24/7 ✦</div>

  <header id="main-header">
    <div class="logo">SKS SHOPPING</div>
    <nav>
      <ul>
        <li><a href="#home" onclick="showPage('home')">Accueil</a></li>
        <li><a href="#shop" onclick="showPage('shop')">Boutique</a></li>
        <li><a href="#categories" onclick="showPage('categories')">Catégories</a></li>
        <li><a href="#about" onclick="showPage('about')">À propos</a></li>
        <li><a href="#contact" onclick="showPage('contact')">Contact</a></li>
      </ul>
    </nav>
    <div class="icons">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>
      </svg>
      <div class="cart-wrapper" onclick="showPage('cart')" style="cursor:pointer">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <div class="badge" id="cart-badge">0</div>
      </div>
    </div>
  </header>

  <main>
    <section id="home" class="page active">
      <div class="hero">
        <div class="hero-content">
          <h1>L'élégance livrée à votre porte</h1>
          <p>Premium Selection, Worldwide Delivery. Découvrez des pièces uniques soigneusement sélectionnées.</p>
          <div class="hero-buttons">
            <button class="btn-gold" onclick="showPage('shop')">Découvrir la collection</button>
            <button class="btn-outline" onclick="showPage('shop')">Voir nouveautés</button>
          </div>
        </div>
      </div>
      <div class="container">
        <div class="trust-banner">
          <div class="trust-item"><h4>Livraison Gratuite</h4><p>Dès 50€ d'achat</p></div>
          <div class="trust-item"><h4>Paiement Sécurisé</h4><p>100% garanti</p></div>
          <div class="trust-item"><h4>Retours Simples</h4><p>Sous 30 jours</p></div>
          <div class="trust-item"><h4>Support 24/7</h4><p>Toujours à votre écoute</p></div>
        </div>
        <h2 class="section-title">Nos univers</h2>
        <div class="product-grid" id="category-showcase"></div>
        <h2 class="section-title">Sélection Vedette</h2>
        <div class="product-grid" id="featured-products"></div>
      </div>
    </section>

    <section id="categories" class="page">
      <div class="container">
        <h2 class="section-title">Toutes nos catégories</h2>
        <div class="product-grid" id="categories-page-grid"></div>
      </div>
    </section>

    <section id="shop" class="page">
      <div class="container">
        <h2 class="section-title">Notre Boutique</h2>
        <div class="shop-layout">
          <aside class="sidebar">
            <div class="filter-group">
              <h4>Catégories</h4>
              <label><input type="checkbox" value="all" checked /> Tout voir</label><br />
              <label><input type="checkbox" value="maison-cuisine" /> Maison & cuisine</label><br />
              <label><input type="checkbox" value="tech" /> Gadgets & tech</label><br />
              <label><input type="checkbox" value="bebe" /> Bébé & enfants</label><br />
              <label><input type="checkbox" value="bricolage" /> Bricolage & outils</label><br />
              <label><input type="checkbox" value="bien-etre" /> Bien-être</label><br />
              <label><input type="checkbox" value="other" /> Divers / autres</label><br />
            </div>
            <div class="filter-group">
              <h4>Recherche</h4>
              <input id="shop-search" type="text" placeholder="Rechercher..." style="width:100%;padding:10px;border:1px solid #d9e9e1;" />
            </div>
            <div class="filter-group">
              <h4>Trier</h4>
              <select id="shop-sort" style="width:100%;padding:10px;border:1px solid #d9e9e1;">
                <option value="default">Sélection recommandée</option>
                <option value="price-asc">Prix croissant</option>
                <option value="price-desc">Prix décroissant</option>
                <option value="rating-desc">Mieux notés</option>
              </select>
            </div>
          </aside>
          <div class="shop-content">
            <div class="product-grid" id="all-products"></div>
          </div>
        </div>
      </div>
    </section>

    <section id="cart" class="page">
      <div class="container">
        <h2 class="section-title">Votre Panier</h2>
        <div class="cart-layout">
          <div class="cart-items">
            <table class="cart-table">
              <thead><tr><th>Produit</th><th>Prix</th><th>Quantité</th><th>Total</th><th></th></tr></thead>
              <tbody id="cart-tbody"></tbody>
            </table>
          </div>
          <div class="cart-summary">
            <h3>Résumé de la commande</h3>
            <hr style="margin:15px 0;border:none;border-top:1px solid #eee" />
            <div class="summary-line"><span>Sous-total</span><span id="cart-subtotal">0,00 €</span></div>
            <div class="summary-line"><span>Livraison</span><span>Gratuite</span></div>
            <div class="summary-line summary-total"><span>Total</span><span id="cart-total">0,00 €</span></div>
            <button class="btn-gold" style="width:100%;margin-top:20px" onclick="showPage('checkout')">Passer la commande</button>
          </div>
        </div>
      </div>
    </section>

    <section id="checkout" class="page">
      <div class="container">
        <h2 class="section-title">Validation de Commande</h2>
        <div style="max-width:760px;margin:0 auto;background:var(--blanc);padding:40px;border-radius:10px;border:1px solid rgba(15,106,79,.08)">
          <form id="checkout-form">
            <h3 style="margin-bottom:20px">1. Adresse de Livraison</h3>
            <input type="text" placeholder="Nom complet" required style="width:100%;padding:10px;margin-bottom:10px" />
            <input type="email" placeholder="Email" required style="width:100%;padding:10px;margin-bottom:10px" />
            <input type="text" placeholder="Adresse" required style="width:100%;padding:10px;margin-bottom:10px" />
            <div style="display:flex;gap:10px;margin-bottom:10px">
              <input type="text" placeholder="Code postal" required style="width:30%;padding:10px" />
              <input type="text" placeholder="Ville" required style="width:70%;padding:10px" />
            </div>
            <input type="text" placeholder="Pays" required style="width:100%;padding:10px;margin-bottom:20px" />
            <h3 style="margin:30px 0 20px">2. Paiement PayPal</h3>
            <div id="paypal-button-container" style="min-height:48px;margin-bottom:16px;"></div>
            <button type="submit" class="btn-gold" style="width:100%;margin-top:20px;">Valider la commande</button>
          </form>
        </div>
      </div>
    </section>

    <section id="about" class="page">
      <div class="container" style="max-width:800px">
        <h2 class="section-title">Notre Histoire</h2>
        <p>SKS SHOPPING est né d'une passion pour le luxe accessible et le design épuré. Une sélection mondiale de produits utiles, tendance et premium dans plusieurs univers.</p>
      </div>
    </section>

    <section id="contact" class="page">
      <div class="container" style="max-width:600px">
        <h2 class="section-title">Nous Contacter</h2>
        <form style="background:var(--blanc);padding:40px;border-radius:4px" onsubmit="event.preventDefault(); showToast('Message envoyé !'); this.reset();">
          <input type="text" placeholder="Votre nom" required style="width:100%;padding:10px;margin-bottom:15px" />
          <input type="email" placeholder="Votre email" required style="width:100%;padding:10px;margin-bottom:15px" />
          <textarea placeholder="Votre message" rows="5" required style="width:100%;padding:10px;margin-bottom:15px;font-family:var(--font-text)"></textarea>
          <button type="submit" class="btn-gold">Envoyer</button>
        </form>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <div class="logo" style="margin-bottom:20px">SKS SHOPPING</div>
          <p style="color:var(--gris);font-size:.9rem">L'élégance livrée à votre porte. Sélections premium multi-niches.</p>
        </div>
        <div class="footer-col">
          <h4>Service Client</h4>
          <ul><li><a href="#">FAQ</a></li><li><a href="#">Livraison & Retours</a></li><li><a href="#">CGV</a></li></ul>
        </div>
        <div class="footer-col">
          <h4>Newsletter</h4>
          <p style="color:var(--gris);font-size:.9rem;margin-bottom:15px">10% de réduction à l'inscription.</p>
          <input type="email" class="newsletter-input" placeholder="Votre email" />
          <button class="newsletter-btn">S'inscrire</button>
        </div>
      </div>
      <div class="footer-bottom">
        <p>VISA • MASTERCARD • PAYPAL • APPLE PAY</p>
        <p style="margin-top:10px">© 2026 SKS SHOPPING - Tous droits réservés.</p>
      </div>
    </div>
  </footer>

  <div id="toast-container"></div>
  <script src="assets/js/app.js"></script>
</body>
</html>
